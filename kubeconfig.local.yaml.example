# ═══════════════════════════════════════════════════════
# Kubeconfig for Telekube local development
# Replace this file content with your actual kubeconfig.
#
# How to get your kubeconfig:
#   EKS:  aws eks update-kubeconfig --name <cluster> --region <region> --kubeconfig ./kubeconfig.local.yaml
#   GKE:  KUBECONFIG=./kubeconfig.local.yaml gcloud container clusters get-credentials <cluster> --zone <zone>
#   AKS:  az aks get-credentials --resource-group <rg> --name <cluster> --file ./kubeconfig.local.yaml
#   Kind: kind export kubeconfig --name <cluster> --kubeconfig ./kubeconfig.local.yaml
#
# ⚠️  If cluster runs locally (kind/minikube), change server URL:
#     127.0.0.1 or localhost → host.docker.internal
# ═══════════════════════════════════════════════════════
apiVersion: v1
kind: Config
current-context: my-cluster-admin@my-cluster

clusters:
- cluster:
    certificate-authority-data: <BASE64_CA_CERT>
    server: https://<CLUSTER_API_SERVER>:6443
  name: my-cluster

contexts:
- context:
    cluster: my-cluster
    user: my-cluster-admin
  name: my-cluster-admin@my-cluster

users:
- name: my-cluster-admin
  user:
    client-certificate-data: <BASE64_CLIENT_CERT>
    client-key-data: <BASE64_CLIENT_KEY>
