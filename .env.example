# ─────────────────────────────────────────────────
# Telekube Local Development – Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# Telegram Bot Token (get from @BotFather)
TELEKUBE_TELEGRAM_TOKEN=your-telegram-bot-token-here

# Your Telegram User ID (comma-separated for multiple admins)
# Get your ID: message @userinfobot on Telegram
TELEKUBE_TELEGRAM_ADMIN_IDS=123456789

# Path to your kubeconfig file (optional, defaults to ~/.kube/config)
# KUBECONFIG_PATH=~/.kube/config
